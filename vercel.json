{
  "version": 2,
  "buildCommand": "npm run build --workspace=apps/web && npm run build --workspace=apps/api",
  "installCommand": "npm install",
  "framework": null,
  "builds": [
    {
      "src": "apps/api/dist/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/api/dist/index.js"
    }
  ]
}
